ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Running via `docker compose up` -------------------------------------
# docker-compose.yml bakes in working defaults for everything below, so
# `docker compose up` needs zero configuration to try the project. Copy this
# file to .env and fill in real values only when you want something other
# than the demo defaults (a real ANTHROPIC_API_KEY, a non-default admin
# password, etc.) — docker-compose.yml reads .env automatically if present.

# Required — signs session cookies (Flask-Login) and CSRF tokens (Flask-WTF).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be stable across restarts and identical across all worker processes in
# production — a randomly-regenerated key would silently invalidate sessions.
# (docker-compose.yml supplies an insecure demo default if this is unset.)
FLASK_SECRET_KEY=

# Every recruiter/admin/viewer is a real account (webapp/models_db.py User,
# hashed password) — no shared admin password. Under Docker Compose, the
# `migrate` service bootstraps one admin account automatically (idempotent —
# safe on every restart) using these three; change ADMIN_PASSWORD from the
# demo default before using this anywhere but your own machine.
# Running locally without Docker instead? Bootstrap it yourself:
#   python scripts/create_user.py --username admin --role admin
# Additional users (any role) can then be created from the dashboard's
# Manage Users page (admin only).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=Administrator

# Postgres connection. Under Docker Compose this is set for you (points at
# the `db` service) — these three only matter for the `db` container's own
# credentials, or for running Postgres yourself outside Docker:
#   docker run -d --name screener-db -e POSTGRES_USER=screener \
#     -e POSTGRES_PASSWORD=screener -e POSTGRES_DB=screener -p 5432:5432 postgres:16
POSTGRES_USER=screener
POSTGRES_PASSWORD=screener
POSTGRES_DB=screener
# Only needed running webapp/app.py directly (not via Docker Compose, which sets this itself):
# DATABASE_URL=postgresql+psycopg2://screener:screener@localhost:5432/screener

# Set to 1 only for local/CI smoke-testing without a real Postgres server.
# Never set this in production.
# SCREENER_ALLOW_SQLITE=1

# Redis — the RQ broker for background resume processing (webapp/tasks.py).
# Under Docker Compose this is set for you (points at the `redis` service).
# Only needed running webapp/app.py directly:
#   docker run -d --name screener-redis -p 6379:6379 redis:7-alpine
# REDIS_URL=redis://localhost:6379/0

# Only relevant if you run Ollama on your host machine while using Docker
# Compose for everything else — docker-compose.yml already points this at
# http://host.docker.internal:11434 so the containers can reach it.
# OLLAMA_BASE_URL=

# Structured (JSON) logging level for both the web app and the worker
# (webapp/logging_config.py). One of DEBUG/INFO/WARNING/ERROR/CRITICAL.
# LOG_LEVEL=INFO
